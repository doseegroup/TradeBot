# ─── Data Provider ────────────────────────────────────────────────────────────
# "yahoo"       : Yahoo Finance (無料、デフォルト)
# "alphavantage": Alpha Vantage (APIキー必要)
# "mock"        : ダミーデータ（テスト用）
DATA_PROVIDER=yahoo
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ─── LINE Messaging API ───────────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_TO=your_line_user_or_group_id_here

# ─── OpenAI (AIレポート、任意) ────────────────────────────────────────────────
# 空の場合はテンプレートベースのレポートを生成
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Paper Trading ────────────────────────────────────────────────────────────
INITIAL_EQUITY=10000        # USD 初期仮想資金
MAX_POSITION_USD=1000       # 1銘柄あたり最大投入額 (USD)

# ─── Strategy ─────────────────────────────────────────────────────────────────
# 以下は src/config/index.ts のデフォルトで設定済み。必要に応じて上書き可
TRAILING_STOP_ENABLED=true

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/tradebot.db

# ─── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info              # debug | info | warn | error
TZ=Asia/Tokyo
