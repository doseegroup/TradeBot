{
  "name": "tradebot",
  "version": "2.0.0",
  "description": "US Stock Paper Trading Research Bot — Node.js + TypeScript + SQLite",
  "scripts": {
    "fetch":     "tsx src/cli/fetch.ts",
    "run":       "tsx src/cli/run.ts",
    "report":    "tsx src/cli/report.ts",
    "backfill":  "tsx src/cli/backfill.ts",
    "init-db":   "tsx src/cli/init-db.ts",
    "dashboard": "tsx src/commands/dashboard.ts",
    "export":    "tsx src/commands/export.ts",
    "test":      "node --require tsx/cjs --test tests/strategy.test.ts tests/pnl.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios":          "^1.7.2",
    "better-sqlite3": "^12.6.2",
    "dotenv":         "^16.4.5",
    "express":        "^4.19.2",
    "openai":         "^4.52.0",
    "winston":        "^3.13.0",
    "yahoo-finance2": "^2.11.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express":        "^4.17.21",
    "@types/node":           "^20.14.0",
    "tsx":                   "^4.16.0",
    "typescript":            "^5.5.0"
  }
}
